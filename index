<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Professional Data Studio - 13 Charts</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;600&display=swap');
        body { font-family: 'Sarabun', sans-serif; background-color: #f8fafc; }
        .sidebar { scrollbar-width: thin; scrollbar-color: #cbd5e1 transparent; }
        .chart-card { background: white; border-radius: 1rem; padding: 1.25rem; border: 1px solid #e2e8f0; transition: transform 0.2s; }
        .chart-card:hover { transform: translateY(-2px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1); }
        .input-group { border-left: 4px solid #6366f1; background: #f1f5f9; padding: 1rem; border-radius: 0.5rem; position: relative; }
    </style>
</head>
<body class="text-slate-800">

    <!-- Sidebar สำหรับควบคุมข้อมูล (ออกแบบมาเพื่อ iPad) -->
    <aside class="fixed top-0 left-0 h-full w-full lg:w-80 bg-white border-r border-slate-200 z-50 overflow-y-auto transform -translate-x-full lg:translate-x-0 transition-transform duration-300" id="sidebar">
        <div class="p-6">
            <div class="flex justify-between items-center mb-6">
                <h2 class="text-2xl font-bold text-indigo-600">⚙️ ตั้งค่าข้อมูล</h2>
                <button onclick="toggleSidebar()" class="lg:hidden text-slate-400 text-3xl">&times;</button>
            </div>

            <!-- Labels Input -->
            <div class="mb-8">
                <label class="block text-sm font-bold text-slate-500 mb-2 uppercase tracking-wider">ชื่อกลุ่ม (Labels)</label>
                <textarea id="labelsInput" oninput="updateAllCharts()" class="w-full p-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 focus:outline-none text-sm" rows="2" placeholder="เช่น Lab 1, Lab 2, Lab 3">Python, Scala, C#, Java, PHP</textarea>
            </div>

            <!-- Datasets Section -->
            <div class="space-y-4" id="datasetList">
                <h3 class="text-sm font-bold text-slate-500 mb-2 uppercase tracking-wider">ชุดข้อมูล (Datasets)</h3>
                <!-- ชุดข้อมูลจะถูกเพิ่มที่นี่ -->
            </div>

            <button onclick="addDataset()" class="w-full mt-6 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 rounded-xl shadow-lg transition-all active:scale-95">
                + เพิ่มชุดข้อมูลใหม่
            </button>
            
            <button onclick="resetData()" class="w-full mt-3 text-slate-400 hover:text-rose-500 text-xs transition-all">
                ล้างข้อมูลและเริ่มต้นใหม่
            </button>
        </div>
    </aside>

    <!-- ส่วนแสดงผลหลัก -->
    <main class="lg:ml-80 min-h-screen p-4 lg:p-8">
        <!-- Mobile Toggle -->
        <div class="lg:hidden mb-6">
            <button onclick="toggleSidebar()" class="w-full bg-white p-4 rounded-xl shadow-sm border border-slate-200 font-bold text-indigo-600">
                📂 เปิดแผงควบคุมข้อมูล
            </button>
        </div>

        <header class="mb-10 text-center lg:text-left">
            <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Data Studio 13 รูปแบบ</h1>
            <p class="text-slate-500 mt-1">อ้างอิงจาก Python Matplotlib - ปรับแต่งและวิเคราะห์แบบเรียลไทม์</p>
        </header>

        <!-- Grid กราฟทั้ง 13 แบบ -->
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
            
            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">1. Grouped Bar Graph</h3>
                <div class="h-60"><canvas id="groupedBar"></canvas></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">2. Horizontal Bar Graph</h3>
                <div class="h-60"><canvas id="horizontalBar"></canvas></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">3. Stacked Bar Graph</h3>
                <div class="h-60"><canvas id="stackedBar"></canvas></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">4. Coloured Bar Graph</h3>
                <div class="h-60"><canvas id="colouredBar"></canvas></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">5. Standard Bar Chart</h3>
                <div class="h-60"><canvas id="standardBar"></canvas></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase text-center">6. Radar Chart</h3>
                <div class="h-60"><canvas id="radarChart"></canvas></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase text-center">7. Pie Chart</h3>
                <div class="h-60"><canvas id="pieChart"></canvas></div>
            </div>

            <div class="chart-card md:col-span-2 xl:col-span-1">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">8. Heatmap (Matrix)</h3>
                <div id="heatmap" class="grid gap-1 bg-slate-100 p-2 rounded-lg overflow-auto max-h-60"></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">9. Box Plot (Range)</h3>
                <div class="h-60"><canvas id="boxPlot"></canvas></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">10. Histogram</h3>
                <div class="h-60"><canvas id="histogram"></canvas></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">11. Area Chart</h3>
                <div class="h-60"><canvas id="areaChart"></canvas></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">12. Scatter Plot</h3>
                <div class="h-60"><canvas id="scatterPlot"></canvas></div>
            </div>

            <div class="chart-card">
                <h3 class="text-sm font-bold text-slate-400 mb-4 uppercase">13. Line Chart</h3>
                <div class="h-60"><canvas id="lineChart"></canvas></div>
            </div>

        </div>
    </main>

    <script>
        const chartInstances = {};
        const palette = ['#6366f1', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4', '#f43f5e'];

        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('-translate-x-full');
        }

        function addDataset(label = "ชุดข้อมูลใหม่", values = "45, 10, 15, 30, 22") {
            const container = document.getElementById('datasetList');
            const id = Date.now();
            const div = document.createElement('div');
            div.className = "input-group relative";
            div.id = `ds-${id}`;
            div.innerHTML = `
                <button onclick="removeDataset(${id})" class="absolute top-1 right-2 text-slate-400 hover:text-rose-500 font-bold">&times;</button>
                <input type="text" value="${label}" oninput="updateAllCharts()" class="ds-name w-full bg-transparent font-bold text-indigo-700 text-sm mb-1 focus:outline-none">
                <input type="text" value="${values}" oninput="updateAllCharts()" class="ds-data w-full bg-white p-2 rounded border border-slate-200 text-xs focus:ring-1 focus:ring-indigo-500">
            `;
            container.appendChild(div);
            updateAllCharts();
        }

        function removeDataset(id) {
            document.getElementById(`ds-${id}`).remove();
            updateAllCharts();
        }

        function getInputs() {
            const labels = document.getElementById('labelsInput').value.split(',').map(s => s.trim());
            const datasets = [];
            document.querySelectorAll('.input-group').forEach((group, i) => {
                const label = group.querySelector('.ds-name').value;
                const data = group.querySelector('.ds-data').value.split(',').map(Number);
                datasets.push({
                    label: label,
                    data: data,
                    backgroundColor: palette[i % palette.length],
                    borderColor: palette[i % palette.length],
                    borderWidth: 2,
                    tension: 0.4,
                    pointRadius: 4
                });
            });
            return { labels, datasets };
        }

        function renderChart(id, type, labels, datasets, options = {}) {
            if (chartInstances[id]) {
                chartInstances[id].data.labels = labels;
                chartInstances[id].data.datasets = datasets;
                chartInstances[id].update('none');
            } else {
                const ctx = document.getElementById(id).getContext('2d');
                chartInstances[id] = new Chart(ctx, {
                    type,
                    data: { labels, datasets },
                    options: { 
                        responsive: true, 
                        maintainAspectRatio: false,
                        plugins: { legend: { display: datasets.length < 5, labels: { boxWidth: 12, font: { size: 10 } } } },
                        ...options 
                    }
                });
            }
        }

        function renderHeatmap(labels, datasets) {
            const container = document.getElementById('heatmap');
            container.innerHTML = '';
            container.style.gridTemplateColumns = `repeat(${labels.length}, 1fr)`;
            
            datasets.forEach(ds => {
                ds.data.forEach((val, i) => {
                    const cell = document.createElement('div');
                    const intensity = Math.min(val / 100, 1);
                    cell.className = 'h-10 flex items-center justify-center text-[10px] font-bold text-white rounded-sm';
                    cell.style.backgroundColor = ds.backgroundColor.replace(')', `, ${intensity})`).replace('rgb', 'rgba');
                    cell.innerText = val;
                    container.appendChild(cell);
                });
            });
        }

        function updateAllCharts() {
            const { labels, datasets } = getInputs();
            if (!datasets.length || !labels.length) return;

            // 1. Grouped Bar
            renderChart('groupedBar', 'bar', labels, datasets);

            // 2. Horizontal Bar
            renderChart('horizontalBar', 'bar', labels, datasets, { indexAxis: 'y' });

            // 3. Stacked Bar
            renderChart('stackedBar', 'bar', labels, datasets, { scales: { x: { stacked: true }, y: { stacked: true } } });

            // 4. Coloured Bar (ชุดข้อมูลแรกใช้สีแยกแต่ละแท่ง)
            const colouredData = [{
                ...datasets[0],
                backgroundColor: palette.slice(0, labels.length)
            }];
            renderChart('colouredBar', 'bar', labels, colouredData, { plugins: { legend: { display: false } } });

            // 5. Standard Bar
            renderChart('standardBar', 'bar', labels, [datasets[0]]);

            // 6. Radar
            renderChart('radarChart', 'radar', labels, datasets.map(d => ({ ...d, fill: true, backgroundColor: d.backgroundColor.replace(')', ', 0.2)').replace('rgb', 'rgba') })));

            // 7. Pie (รวมยอดแต่ละชุด)
            renderChart('pieChart', 'pie', datasets.map(d => d.label), [{
                data: datasets.map(d => d.data.reduce((a, b) => a + b, 0)),
                backgroundColor: palette
            }]);

            // 8. Heatmap
            renderHeatmap(labels, datasets);

            // 9. Box Plot Look (Floating Bar)
            const boxData = datasets.map(d => ({
                label: d.label,
                data: d.data.map(v => [v - 5, v + 5]), // จำลองช่วงความแปรปรวน
                backgroundColor: d.backgroundColor
            }));
            renderChart('boxPlot', 'bar', labels, boxData);

            // 10. Histogram
            renderChart('histogram', 'bar', labels, datasets, { barPercentage: 1.2, categoryPercentage: 1.0 });

            // 11. Area
            renderChart('areaChart', 'line', labels, datasets.map(d => ({ ...d, fill: true, backgroundColor: d.backgroundColor.replace(')', ', 0.1)').replace('rgb', 'rgba') })));

            // 12. Scatter
            const scatterData = datasets[0].data.map((v, i) => ({ x: i + 1, y: v }));
            renderChart('scatterPlot', 'scatter', labels, [{ label: 'จุดข้อมูล', data: scatterData, backgroundColor: palette[0] }]);

            // 13. Line
            renderChart('lineChart', 'line', labels, datasets);
        }

        function resetData() {
            document.getElementById('datasetList').innerHTML = '';
            document.getElementById('labelsInput').value = "Lab 1, Lab 2, Lab 3, Lab 4, Lab 5";
            addDataset("Team A", "60, 75, 56, 62, 58");
            addDataset("Team B", "55, 68, 80, 73, 55");
        }

        window.onload = resetData;
    </script>
</body>
</html>
